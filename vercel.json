{
  "experimentalServices": {
    "web": {
      "root": ".",
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "vite"
    },
    "api": {
      "root": "backend",
      "entrypoint": "server.js",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api|assets|favicon|og_image|.*\\..*).*)$",
      "destination": "/index.html"
    }
  ]
}
