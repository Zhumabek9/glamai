{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/config",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|assets|favicon|og_image|.*\\..*).*)$",
      "destination": "/index.html"
    }
  ]
}
