{
  "experimentalServices": {
    "web": {
      "root": ".",
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm install && npm run build"
    },
    "api": {
      "root": ".",
      "entrypoint": "api/index.js",
      "routePrefix": "/api",
      "buildCommand": "cd backend && npm install"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api|assets|favicon|og_image|.*\\..*).*)$",
      "destination": "/index.html"
    }
  ]
}
